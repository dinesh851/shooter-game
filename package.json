{
  "name": "lan-shooter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based LAN multiplayer first-person shooter (Three.js + Colyseus)",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.37",
    "@colyseus/ws-transport": "^0.15.3",
    "@dgreenheck/ez-tree": "^1.1.0",
    "colyseus": "^0.15.17",
    "colyseus.js": "^0.15.28",
    "express": "^4.19.2",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/three": "^0.170.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "puppeteer-core": "^24.43.1",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "vite": "^5.2.6"
  }
}
